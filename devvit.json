{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "ez-automod",
  "permissions": {
    "http": {
      "enable": false
    },
    "media": false,
    "realtime": false,
    "redis": true,
    "reddit": {
      "enable": true
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "menu": {
    "items": [
      {
        "label": "Automod",
