{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "automod-app",
  "permissions": {
    "http": {
      "enable": false
    },
    "media": false,
    "realtime": false,
    "redis": true,
    "reddit": {
      "enable": true
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "settings": {
    "subreddit": {
      "replace-quotes": {
        "type": "boolean",
        "label": "Replace smart quotes",
        "helpText": "If enabled, smart quotes (‘’/“”) will be replaced with standard quotes ('/\") to avoid formatting errors on mobile.",
        "defaultValue": false
      },
      "replace-em-dash": {
        "type": "boolean",
        "label": "Replace em-dash-and-hyphen",
        "helpText": "If enabled, a combination of em-dash followed immediately by a hyphen (—-) will be replaced with three hyphens (---) to avoid formatting errors on mobile.",
        "defaultValue": false
      }
    }
  },
  "menu": {
    "items": [
      {
        "label": "Automod",
        "forUserType": "moderator",
        "location": [
          "subreddit"
        ],
        "endpoint": "/internal/menu/edit-automod"
      }
    ]
  },
  "forms": {
    "editAutomodForm": "/internal/forms/edit-automod-submit"
  },
  "marketingAssets": {
    "icon": "assets/ma-icon.png"
  },
  "dev": {
    "subreddit": "CapitalOneBank"
  }
}